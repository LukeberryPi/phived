# Phived Pro backend (apps/api) environment. Set these in Railway service
# variables. When DATABASE_URL, BETTER_AUTH_SECRET, and TASKS_ENC_KEY are all
# absent the service serves the static site only (Pro disabled) — see ADR 0004.

# --- Runtime (Railway injects PORT; set BIND_HOST in production) ---
# PORT=3000
# BIND_HOST=0.0.0.0

# --- Database (Railway Postgres plugin injects DATABASE_URL) ---
DATABASE_URL=postgres://user:password@host:5432/phived

# --- Better Auth ---
# Generate a 32+ byte random secret, e.g. `openssl rand -base64 32`.
BETTER_AUTH_SECRET=
# Public origin of the deployment (used for cookies, redirects, trusted origins).
BETTER_AUTH_URL=https://www.phived.com

# --- Google OAuth (Authorized redirect URI: <BETTER_AUTH_URL>/api/auth/callback/google) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Polar billing ---
# Webhook URL to configure in Polar: <BETTER_AUTH_URL>/api/auth/polar/webhooks
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_PRODUCT_ID_MONTHLY=
POLAR_PRODUCT_ID_ANNUAL=
# "production" (default) or "sandbox".
POLAR_SERVER=production

# --- Task document encryption (AES-256-GCM) ---
# 32 bytes, base64-encoded, e.g. `openssl rand -base64 32`.
TASKS_ENC_KEY=
