---
import Base from "../layouts/Base.astro";

const appUrl = "/app";
const githubUrl = "https://github.com/lukeberrypi/phived";

const principles = [
  { label: "no login", note: "open it and start. nothing to sign up for." },
  { label: "no cookies", note: "no banners to dismiss, no consent theatre." },
  { label: "no images", note: "nothing to load, nothing to gawk at." },
  { label: "no ads", note: "the page is for your tasks, not for sale." },
];

const steps = [
  {
    n: "01",
    title: "write your next few steps",
    body: "spawn tagged lists on the canvas and add your next few steps. no projects, no due dates, no fuss.",
  },
  {
    n: "02",
    title: "focus on what's in front of you",
    body: "a short list is a finishable list. the canvas stays quiet so your attention doesn't wander.",
  },
  {
    n: "03",
    title: "press done and watch it clear",
    body: "finished tasks move to history. clear the board, breathe, and line up the next few.",
  },
];

const faqs = [
  {
    q: "is it free?",
    a: "yes. completely free, and open source. no plans, no upsells, no premium tier.",
  },
  {
    q: "do you store my data?",
    a: "no. your tasks live in your browser's local storage. there's no account and no server keeping a copy.",
  },
  {
    q: "why keep lists short?",
    a: "because a wall of fifty to-dos is just procrastination with extra steps. a few next steps per list is what actually gets done.",
  },
  {
    q: "is there a native app?",
    a: "yes — there's a native macOS build alongside the web app, sharing the same calm design.",
  },
];
---

<Base>
  <a
    href="#main"
    class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-white focus:px-4 focus:py-2 focus:text-sm focus:text-black focus:shadow-brutalist-light dark:focus:bg-surface-dark dark:focus:text-ink-dark"
  >
    skip to content
  </a>

  <!-- ───────────────────────── nav ───────────────────────── -->
  <header
    class="mx-auto flex max-w-5xl items-center justify-between px-6 py-6"
  >
    <a
      href="/"
      class="text-lg font-medium tracking-tight lowercase"
      aria-label="phived home"
    >
      phived<span class="text-muted-light dark:text-muted-dark">.</span>
    </a>

    <nav class="flex items-center gap-1 sm:gap-2">
      <a
        href={githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden rounded-full px-3 py-1.5 text-sm text-muted-light transition-colors hover:text-[#080811] sm:inline-block dark:text-muted-dark dark:hover:text-ink-dark"
      >
        github
      </a>
      <button
        id="theme-toggle"
        type="button"
        aria-label="toggle theme"
        class="grid size-9 place-items-center rounded-full text-muted-light transition-colors hover:bg-surface-hover-light hover:text-[#080811] dark:text-muted-dark dark:hover:bg-surface-hover-dark dark:hover:text-ink-dark"
      >
        <svg class="size-5 dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path>
        </svg>
        <svg class="hidden size-5 dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
        </svg>
      </button>
      <a
        href={appUrl}
        class="rounded-full border border-black bg-white px-4 py-1.5 text-sm font-medium text-[#080811] shadow-brutalist-light transition-transform hover:-translate-y-0.5 dark:border-edge-dark dark:bg-surface-dark dark:text-ink-dark dark:shadow-brutalist-dark"
      >
        open app
      </a>
    </nav>
  </header>

  <main id="main">
    <!-- ───────────────────────── hero ───────────────────────── -->
    <section class="mx-auto max-w-5xl px-6 pb-20 pt-12 sm:pt-20">
      <div class="grid items-center gap-14 lg:grid-cols-[1.05fr_0.95fr]">
        <div>
          <p
            class="reveal text-xs font-medium uppercase tracking-[0.2em] text-muted-light dark:text-muted-dark"
            style="animation-delay: 0ms"
          >
            the anti-procrastination to-do list
          </p>
          <h1
            class="reveal mt-6 text-balance text-5xl font-light leading-[0.98] tracking-tight sm:text-6xl md:text-7xl"
            style="animation-delay: 80ms"
          >
            just you and your<br />
            <span class="font-medium">next few steps.</span>
          </h1>
          <p
            class="reveal mt-7 max-w-md text-lg leading-relaxed text-muted-light dark:text-muted-dark"
            style="animation-delay: 160ms"
          >
            ever opened a website just to be buried in cookie modals,
            newsletter beggars, and ads? phived is the opposite. a quiet
            canvas, tagged lists for your next few steps, and nothing trying to
            keep you there.
          </p>
          <div
            class="reveal mt-9 flex flex-wrap items-center gap-3"
            style="animation-delay: 240ms"
          >
            <a
              href={appUrl}
              class="rounded-full border border-black bg-[#080811] px-6 py-3 text-base font-medium text-white shadow-brutalist-light transition-transform hover:-translate-y-0.5 dark:border-edge-dark dark:bg-ink-dark dark:text-canvas-dark dark:shadow-brutalist-dark"
            >
              open phived →
            </a>
            <a
              href={githubUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-full px-5 py-3 text-base text-muted-light underline-offset-4 transition-colors hover:text-[#080811] hover:underline dark:text-muted-dark dark:hover:text-ink-dark"
            >
              view source
            </a>
          </div>
        </div>

        <!-- live mini demo, built from the real tokens -->
        <div
          class="reveal lg:justify-self-end"
          style="animation-delay: 320ms"
          aria-hidden="true"
        >
          <div
            class="w-full max-w-sm rounded-2xl border border-black bg-white p-5 shadow-brutalist-light dark:border-edge-dark dark:bg-surface-dark dark:shadow-brutalist-dark"
          >
            <div class="mb-4 flex items-center justify-between">
              <span
                class="rounded-full border border-line-light px-2.5 py-0.5 text-xs font-medium lowercase text-muted-light dark:border-hairline-dark dark:text-muted-dark"
              >
                today
              </span>
              <span class="text-xs text-muted-light dark:text-muted-dark">2 done</span>
            </div>

            <ul class="space-y-2 text-[15px]">
              <li class="flex items-center gap-3 rounded-lg px-2 py-2 line-through decoration-line-light text-muted-light dark:text-muted-dark">
                <span class="grid size-5 place-items-center rounded-full border border-line-light text-[10px] dark:border-hairline-dark">✓</span>
                brew some coffee
              </li>
              <li class="flex items-center gap-3 rounded-lg px-2 py-2 line-through decoration-line-light text-muted-light dark:text-muted-dark">
                <span class="grid size-5 place-items-center rounded-full border border-line-light text-[10px] dark:border-hairline-dark">✓</span>
                read 10 pages of your book
              </li>
              <li class="flex items-center gap-3 rounded-lg bg-surface-hover-light px-2 py-2 dark:bg-surface-hover-dark">
                <span class="grid size-5 place-items-center rounded-full border border-black dark:border-edge-dark"></span>
                walk for 20 minutes
              </li>
              <li class="flex items-center gap-3 rounded-lg px-2 py-2 text-muted-light dark:text-muted-dark">
                <span class="grid size-5 place-items-center rounded-full border border-line-light dark:border-hairline-dark"></span>
                call grandma
              </li>
              <li class="flex items-center gap-3 rounded-lg px-2 py-2 text-muted-light dark:text-muted-dark">
                <span class="grid size-5 place-items-center rounded-full border border-line-light dark:border-hairline-dark"></span>
                drink 2L water
              </li>
            </ul>

            <button
              type="button"
              tabindex="-1"
              class="mt-4 w-full rounded-xl border border-black bg-white py-2.5 text-sm font-medium shadow-brutalist-light dark:border-edge-dark dark:bg-surface-hover-dark dark:shadow-brutalist-dark"
            >
              done
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- ───────────────────────── principles ───────────────────────── -->
    <section class="rule-y">
      <div class="mx-auto max-w-5xl px-6">
        <div
          class="grid grid-cols-1 divide-y divide-line-light sm:grid-cols-2 sm:divide-x lg:grid-cols-4 dark:divide-hairline-dark"
        >
          {
            principles.map((p) => (
              <div class="px-0 py-9 sm:px-7">
                <p class="text-xl font-medium lowercase tracking-tight">
                  {p.label}
                </p>
                <p class="mt-2 text-sm leading-relaxed text-muted-light dark:text-muted-dark">
                  {p.note}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ───────────────────────── how it works ───────────────────────── -->
    <section class="rule-y">
      <div class="mx-auto max-w-5xl px-6 py-20 sm:py-28">
        <header class="mb-14 max-w-xl">
          <p class="text-xs font-medium uppercase tracking-[0.2em] text-muted-light dark:text-muted-dark">
            how it works
          </p>
          <h2 class="mt-4 text-3xl font-light tracking-tight sm:text-4xl">
            a shorter list is a <span class="font-medium">finishable</span> list.
          </h2>
        </header>

        <div class="grid gap-px overflow-hidden rounded-2xl border border-line-light sm:grid-cols-3 dark:border-hairline-dark">
          {
            steps.map((s) => (
              <div class="bg-canvas-light p-8 dark:bg-surface-dark">
                <span class="font-mono text-sm text-muted-light dark:text-muted-dark">
                  {s.n}
                </span>
                <h3 class="mt-5 text-lg font-medium lowercase tracking-tight">
                  {s.title}
                </h3>
                <p class="mt-3 text-sm leading-relaxed text-muted-light dark:text-muted-dark">
                  {s.body}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ───────────────────────── faq ───────────────────────── -->
    <section class="rule-y">
      <div class="mx-auto grid max-w-5xl gap-12 px-6 py-20 sm:py-28 lg:grid-cols-[0.4fr_0.6fr]">
        <header>
          <p class="text-xs font-medium uppercase tracking-[0.2em] text-muted-light dark:text-muted-dark">
            questions
          </p>
          <h2 class="mt-4 text-3xl font-light tracking-tight sm:text-4xl">
            the short <span class="font-medium">answers.</span>
          </h2>
        </header>

        <div>
          {
            faqs.map((f, i) => (
              <details
                class="group border-line-light py-5 dark:border-hairline-dark [&:not(:first-child)]:border-t"
                open={i === 0}
              >
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-lg lowercase">
                  {f.q}
                  <span class="text-muted-light transition-transform duration-200 group-open:rotate-45 dark:text-muted-dark">
                    +
                  </span>
                </summary>
                <p class="mt-3 max-w-prose text-[15px] leading-relaxed text-muted-light dark:text-muted-dark">
                  {f.a}
                </p>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ───────────────────────── closing cta ───────────────────────── -->
    <section class="rule-y">
      <div
        class="mx-auto flex max-w-5xl flex-col items-center gap-7 px-6 py-24 text-center sm:py-32"
      >
        <h2 class="text-balance text-4xl font-light tracking-tight sm:text-5xl">
          stop reading. <span class="font-medium">start doing.</span>
        </h2>
        <a
          href={appUrl}
          class="rounded-full border border-black bg-[#080811] px-7 py-3.5 text-base font-medium text-white shadow-brutalist-light transition-transform hover:-translate-y-0.5 dark:border-edge-dark dark:bg-ink-dark dark:text-canvas-dark dark:shadow-brutalist-dark"
        >
          open phived →
        </a>
      </div>
    </section>
  </main>

  <!-- ───────────────────────── footer ───────────────────────── -->
  <footer class="rule-y">
    <div
      class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-4 px-6 py-10 text-sm text-muted-light sm:flex-row dark:text-muted-dark"
    >
      <p class="lowercase">just you and your next few steps.</p>
      <div class="flex items-center gap-5">
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="transition-colors hover:text-[#080811] dark:hover:text-ink-dark"
        >
          github
        </a>
        <a
          href={appUrl}
          class="transition-colors hover:text-[#080811] dark:hover:text-ink-dark"
        >
          open app
        </a>
        <span aria-hidden="true">·</span>
        <span>open source</span>
      </div>
    </div>
  </footer>

  <script is:inline>
    const themeCycle = ["system", "dark", "light"];
    const themeToggle = document.getElementById("theme-toggle");
    const systemDarkQuery = "(prefers-color-scheme: dark)";

    function getStoredThemePreference() {
      const stored = localStorage.getItem("theme");
      return stored === "dark" || stored === "light" ? stored : "system";
    }

    function applyThemePreference(preference) {
      const prefersDark =
        window.matchMedia(systemDarkQuery).matches;
      const isDark =
        preference === "dark" ||
        (preference === "system" && prefersDark);
      document.documentElement.classList.toggle("dark", isDark);
      localStorage.setItem("theme", preference);
      themeToggle?.setAttribute("aria-label", `Theme: ${preference}`);
    }

    applyThemePreference(getStoredThemePreference());

    themeToggle?.addEventListener("click", () => {
      const current = getStoredThemePreference();
      const currentIndex = themeCycle.indexOf(current);
      const next = themeCycle[(currentIndex + 1) % themeCycle.length];
      applyThemePreference(next);
    });
  </script>
</Base>
