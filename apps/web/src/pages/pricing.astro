---
import Base from "../layouts/Base.astro";
import Button from "../components/Button.astro";
import ThemeIndicator from "../components/ThemeIndicator.astro";
import { appHref } from "../../../../scripts/site-contract.mjs";

const githubUrl = "https://github.com/lukeberrypi/phived";
const upgradeHref = `${appHref}?upgrade=1`;
const signinHref = `${appHref}?signin=1`;

const freePoints = [
  "the full task canvas",
  "tagged lists, history, hotkeys",
  "tasks saved in this browser",
  "no account, no tracking cookies",
];

const proPoints = [
  "everything in free",
  "your tasks synced across devices",
  "encrypted at rest on the server",
  "sign in with google, cancel anytime",
];

const faqs = [
  {
    q: "is free changing?",
    a: "No. Free stays exactly as it is — local-only, anonymous, instant. Pro is an optional layer on top.",
  },
  {
    q: "what happens if i stop paying?",
    a: "Nothing is deleted. Phived falls back to saving locally with all your tasks intact, and resumes syncing if you resubscribe.",
  },
  {
    q: "is it really just one cookie?",
    a: "Pro uses a single essential session cookie so you stay signed in. Analytics is cookieless. Free users set no cookies at all.",
  },
];
---

<Base
  title="phived pro — synced, encrypted, still calm"
  description="Phived Pro syncs your tasks across devices, encrypted at rest, while free stays local-only and instant. Monthly or annual."
>
  <header
    class="border-line-light bg-canvas-light/90 dark:border-hairline-dark dark:bg-canvas-dark/90 sticky top-0 z-50 border-b backdrop-blur"
  >
    <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
      <a
        href="/"
        class="ease-out-strong dark:text-ink-dark text-4xl font-normal text-black underline decoration-sky-300 decoration-3 underline-offset-4 transition-transform duration-150 active:scale-95 motion-reduce:transform-none dark:decoration-cyan-800"
        aria-label="phived home"
      >
        phived
      </a>

      <nav class="flex items-center gap-2 sm:gap-3">
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="hidden text-sm font-medium lowercase underline-offset-4 hover:underline sm:inline-block"
        >
          github
        </a>
        <Button
          id="theme-toggle"
          type="button"
          variant="ghost"
          size="icon"
          aria-label="Theme: system"
        >
          <ThemeIndicator />
        </Button>
        <Button
          as="a"
          href={appHref}
          variant="accent"
          size="sm"
          class="lowercase"
        >
          open app
        </Button>
      </nav>
    </div>
  </header>

  <main id="main">
    <section class="mx-auto max-w-5xl px-6 pt-14 pb-10 text-center sm:pt-20">
      <p class="eyebrow">pricing</p>
      <h1
        class="mt-7 text-5xl leading-[0.9] font-bold tracking-tight text-balance lowercase sm:text-6xl"
      >
        stay calm.<br /><span class="highlight">sync everywhere.</span>
      </h1>
      <p
        class="copy text-muted-light dark:text-muted-dark mx-auto mt-7 max-w-md text-lg leading-relaxed"
      >
        Free is local-only and always will be. Phived Pro keeps the exact same
        canvas and quietly syncs it across your devices, encrypted at rest.
      </p>

      <div
        class="dark:border-edge-dark mt-9 inline-flex items-center gap-1 rounded-2xl border border-black p-1"
        role="group"
        aria-label="billing period"
      >
        <button
          type="button"
          id="bill-monthly"
          data-active="true"
          class="bill-toggle rounded-xl px-4 py-2 text-sm font-medium lowercase"
        >
          monthly
        </button>
        <button
          type="button"
          id="bill-annual"
          data-active="false"
          class="bill-toggle rounded-xl px-4 py-2 text-sm font-medium lowercase"
        >
          annual <span class="text-xs opacity-70">· 2 months free</span>
        </button>
      </div>
    </section>

    <section class="mx-auto max-w-5xl px-6 pb-20 sm:pb-28">
      <div class="grid gap-7 sm:grid-cols-2">
        <!-- Free -->
        <div
          class="dark:border-edge-dark dark:bg-surface-dark flex flex-col rounded-2xl border border-black bg-white p-8"
        >
          <h2 class="text-2xl font-bold tracking-tight lowercase">free</h2>
          <p class="mt-4 flex items-baseline gap-1">
            <span class="text-5xl font-bold tracking-tight">$0</span>
            <span class="text-muted-light dark:text-muted-dark lowercase">
              forever
            </span>
          </p>
          <ul class="copy mt-7 flex flex-col gap-3 text-[15px]">
            {
              freePoints.map((point) => (
                <li class="flex items-start gap-3">
                  <span class="text-sky-400 dark:text-cyan-500">/</span>
                  {point}
                </li>
              ))
            }
          </ul>
          <div class="mt-8 pt-2">
            <Button
              as="a"
              href={appHref}
              variant="surface"
              size="lg"
              class="w-full lowercase"
            >
              open phived →
            </Button>
          </div>
        </div>

        <!-- Pro -->
        <div
          class="canvas-dots brutal-shadow-lg dark:border-edge-dark dark:bg-canvas-dark relative flex flex-col rounded-2xl border border-black bg-white p-8"
        >
          <span
            class="text-ink-light dark:border-edge-dark dark:text-ink-dark absolute -top-3 right-6 inline-block rounded-lg border border-black bg-sky-300 px-3 py-1 text-xs font-bold lowercase dark:bg-cyan-800"
          >
            phived pro
          </span>
          <h2 class="text-2xl font-bold tracking-tight lowercase">pro</h2>
          <p class="mt-4 flex items-baseline gap-1">
            <span
              id="pro-price"
              data-monthly="$3"
              data-annual="$30"
              class="text-5xl font-bold tracking-tight">$3</span
            >
            <span
              id="pro-period"
              class="text-muted-light dark:text-muted-dark lowercase"
            >
              / month
            </span>
          </p>
          <ul class="copy mt-7 flex flex-col gap-3 text-[15px]">
            {
              proPoints.map((point) => (
                <li class="flex items-start gap-3">
                  <span class="text-sky-400 dark:text-cyan-500">/</span>
                  {point}
                </li>
              ))
            }
          </ul>
          <div class="mt-8 flex flex-col gap-3 pt-2">
            <Button
              as="a"
              href={upgradeHref}
              variant="accent"
              size="lg"
              data-analytics="upgrade-cta"
              class="w-full lowercase"
            >
              upgrade to pro →
            </Button>
            <a
              href={signinHref}
              class="text-muted-light hover:text-ink-light dark:text-muted-dark dark:hover:text-ink-dark text-center text-sm lowercase underline-offset-4 hover:underline"
            >
              already pro? sign in
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="rule-y dark:bg-surface-dark bg-white">
      <div
        class="mx-auto grid max-w-5xl gap-12 px-6 py-20 sm:py-24 lg:grid-cols-[0.4fr_0.6fr]"
      >
        <header>
          <p class="eyebrow">questions</p>
          <h2
            class="mt-6 text-3xl font-bold tracking-tight lowercase sm:text-4xl"
          >
            the short <span class="highlight">answers.</span>
          </h2>
        </header>
        <div class="flex flex-col gap-4">
          {
            faqs.map((f, i) => (
              <details
                class="group dark:border-edge-dark dark:bg-surface-dark rounded-xl border border-black bg-white px-5"
                open={i === 0}
              >
                <summary class="copy flex cursor-pointer list-none items-center justify-between gap-4 py-4 text-lg font-bold">
                  {f.q}
                  <span class="text-ink-light ease-out-strong dark:border-edge-dark dark:text-ink-dark grid size-7 shrink-0 place-items-center rounded-lg border border-black bg-sky-300 text-lg leading-none transition-transform duration-150 group-open:rotate-45 dark:bg-cyan-800">
                    +
                  </span>
                </summary>
                <p class="copy text-muted-light dark:text-muted-dark mb-5 max-w-prose text-[15px] leading-relaxed">
                  {f.a}
                </p>
              </details>
            ))
          }
        </div>
      </div>
    </section>
  </main>

  <footer>
    <div
      class="text-muted-light dark:text-muted-dark mx-auto flex max-w-5xl flex-col items-center justify-between gap-4 px-6 py-10 text-sm sm:flex-row"
    >
      <p class="lowercase">just you and your next few steps.</p>
      <div class="flex items-center gap-5">
        <a
          href="/"
          class="hover:text-ink-light dark:hover:text-ink-dark lowercase underline-offset-4 hover:underline"
        >
          home
        </a>
        <a
          href={appHref}
          class="hover:text-ink-light dark:hover:text-ink-dark lowercase underline-offset-4 hover:underline"
        >
          open app
        </a>
      </div>
    </div>
  </footer>

  <style>
    .bill-toggle[data-active="true"] {
      background-color: var(--color-ink-light);
      color: var(--color-paper-light);
    }
    :global(.dark) .bill-toggle[data-active="true"] {
      background-color: var(--color-ink-dark);
      color: var(--color-canvas-dark);
    }
  </style>

  <script is:inline>
    const themeCycle = ["system", "dark", "light"];
    const themeToggle = document.getElementById("theme-toggle");
    const systemDarkQuery = "(prefers-color-scheme: dark)";

    function getStoredThemePreference() {
      const stored = localStorage.getItem("theme");
      return stored === "dark" || stored === "light" ? stored : "system";
    }

    function applyThemePreference(preference) {
      const prefersDark = window.matchMedia(systemDarkQuery).matches;
      const isDark =
        preference === "dark" || (preference === "system" && prefersDark);
      document.documentElement.classList.toggle("dark", isDark);
      document.documentElement.dataset.themePreference = preference;
      localStorage.setItem("theme", preference);
      themeToggle?.setAttribute("aria-label", `Theme: ${preference}`);
    }

    applyThemePreference(getStoredThemePreference());

    themeToggle?.addEventListener("click", () => {
      const current = getStoredThemePreference();
      const currentIndex = themeCycle.indexOf(current);
      const next = themeCycle[(currentIndex + 1) % themeCycle.length];
      applyThemePreference(next);
    });

    // Billing period toggle: swaps the displayed Pro price (cosmetic; the actual
    // plan is chosen at checkout). Kept JS-tiny in the spirit of the site.
    const monthlyBtn = document.getElementById("bill-monthly");
    const annualBtn = document.getElementById("bill-annual");
    const price = document.getElementById("pro-price");
    const period = document.getElementById("pro-period");

    function setPeriod(isAnnual) {
      monthlyBtn?.setAttribute("data-active", String(!isAnnual));
      annualBtn?.setAttribute("data-active", String(isAnnual));
      if (price && period) {
        price.textContent = isAnnual
          ? price.dataset.annual
          : price.dataset.monthly;
        period.textContent = isAnnual ? "/ year" : "/ month";
      }
    }

    monthlyBtn?.addEventListener("click", () => setPeriod(false));
    annualBtn?.addEventListener("click", () => setPeriod(true));

    // Cookieless funnel signal for the upgrade CTA.
    document.querySelectorAll("[data-analytics]").forEach((el) => {
      el.addEventListener("click", () => {
        window.gtag?.("event", el.getAttribute("data-analytics"));
      });
    });
  </script>
</Base>
