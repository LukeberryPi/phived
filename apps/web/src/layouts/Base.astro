---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "phived — the anti-procrastination to-do list",
  description = "Phived is a dead-simple, anti-procrastination to-do list. No cookies, no images, no ads. Just you and your next few steps.",
} = Astro.props;

const canonical = "https://www.phived.com/";
const ogImage = "https://www.phived.com/share-banner.png";
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="productive, procrastination, task, list, to-do"
    />
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />

    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:domain" content="phived.com" />
    <meta property="twitter:url" content={canonical} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {
      /* Origin-level Search Console verification lives on the web root, which
        owns phived.com/ (see ADR 0002). */
    }
    <meta
      name="google-site-verification"
      content="R6_yqIps0bS9JxwYUtpbusnOBIb6KfY4Aiwx9TruGZs"
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,700&display=swap"
      rel="stylesheet"
    />

    {
      /* No-flash theme boot. Intentionally mirrors apps/app/index.html and
        getStoredThemePreference() in apps/app/src/utils/isThemeSetToDark.ts.
        Stored values: "system" (follow OS), "dark", "light". Missing or
        invalid values are treated as "system". */
    }
    <script is:inline>
      const stored = localStorage.getItem("theme");
      const prefersDark =
        window?.matchMedia?.("(prefers-color-scheme: dark)")?.matches ?? false;
      const preference =
        stored === "dark" || stored === "light" ? stored : "system";
      const isDark =
        preference === "dark" || (preference === "system" && prefersDark);
      document.documentElement.classList.toggle("dark", isDark);
      document.documentElement.dataset.themePreference = preference;
    </script>

    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-NC0FFZ2WB2"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        // eslint-disable-next-line prefer-rest-params -- canonical Google Analytics snippet
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-NC0FFZ2WB2");
    </script>
  </head>
  <body
    class="canvas-dots bg-canvas-light text-ink-light dark:bg-canvas-dark dark:text-ink-dark min-h-full antialiased"
  >
    <slot />
  </body>
</html>
