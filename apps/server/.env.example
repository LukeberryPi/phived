# apps/server environment. For local dev, copy to apps/server/.env (loaded by
# `bun run dev:server`) or to the repo root .env (loaded by `bun run start`).
# In production these are Railway service variables, NOT a committed file.
# See plans/008-backend-foundation.md and docs/adr/0005.

# Postgres connection (pooled is fine for the app connection).
DATABASE_URL=

# Better Auth. BETTER_AUTH_SECRET must be at least 32 characters (e.g.
# `openssl rand -base64 32`); a shorter value fails startup.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://phived.com

# Google OAuth (redirect URI: <BETTER_AUTH_URL>/api/auth/callback/google).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Polar (use sandbox first). Webhook endpoint: <BETTER_AUTH_URL>/api/auth/polar/webhooks
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_PRODUCT_ID_MONTHLY=
POLAR_PRODUCT_ID_ANNUAL=
POLAR_SERVER=sandbox

# Server bind (ADR 0003). PORT is injected by Railway; BIND_HOST=0.0.0.0 in prod.
PORT=3000
BIND_HOST=0.0.0.0
