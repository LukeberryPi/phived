{
  "name": "phived",
  "private": true,
  "version": "1.3.0",
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "bun --cwd apps/web dev",
    "build": "bun run build:web && bun run build:macos",
    "build:web": "bun --cwd apps/web build",
    "build:macos": "sh apps/macos-app/scripts/build-app.sh",
    "dev:macos": "bun run build:macos && open apps/macos-app/dist/Phived.app",
    "lint": "bun --cwd apps/web lint",
    "typecheck": "bun --cwd apps/web typecheck",
    "test:web": "bun --cwd apps/web test",
    "preview": "bun --cwd apps/web preview",
    "test:macos": "bun run build:macos && PHIVED_SELF_TEST=1 apps/macos-app/dist/Phived.app/Contents/MacOS/Phived",
    "test:macos:xctest": "swift test --package-path apps/macos-app"
  }
}
