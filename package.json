{
  "name": "phived",
  "private": true,
  "version": "1.3.0",
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "apps/app",
    "apps/server",
    "apps/web",
    "packages/tokens",
    "packages/ui"
  ],
  "scripts": {
    "dev": "bun run dev:app & bun run dev:web & wait",
    "dev:app": "bun --cwd apps/app dev",
    "dev:web": "bun --cwd apps/web dev",
    "dev:server": "bun --cwd apps/server dev",
    "build": "bun run build:site",
    "build:app": "bun --cwd apps/app build",
    "build:web": "bun --cwd apps/web build",
    "build:site": "bun scripts/build-site.mjs",
    "start": "bun apps/server/src/index.ts",
    "lint": "bun run lint:app && bun run lint:web && bun run lint:packages && bun run lint:scripts && bun run lint:server",
    "lint:app": "bun --cwd apps/app lint",
    "lint:web": "bun --cwd apps/web lint",
    "lint:packages": "eslint packages --max-warnings 0",
    "lint:scripts": "eslint scripts --max-warnings 0",
    "lint:server": "eslint apps/server --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "bun run typecheck:app && bun run typecheck:web && bun run typecheck:packages && bun run typecheck:server",
    "typecheck:app": "bun --cwd apps/app typecheck",
    "typecheck:web": "bun --cwd apps/web typecheck",
    "typecheck:packages": "tsc -p packages/ui/tsconfig.json --noEmit",
    "typecheck:server": "bun --cwd apps/server typecheck",
    "test:app": "bun --cwd apps/app test",
    "test:scripts": "bun test scripts",
    "test:server": "bun --cwd apps/server test",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run test:app && bun run test:scripts && bun run test:server && bun run build:site",
    "preview": "bun run build:site && bun apps/server/src/index.ts",
    "preview:app": "bun --cwd apps/app preview",
    "preview:web": "bun --cwd apps/web preview",
    "prepare": "lefthook install || true"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^15.14.0",
    "lefthook": "^2.1.9",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
