{
  "name": "phived",
  "private": true,
  "version": "1.3.0",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "npm run dev --workspace apps/web",
    "build": "npm run build:web && npm run build:macos",
    "build:web": "npm run build --workspace apps/web",
    "build:macos": "sh apps/macos-app/scripts/build-app.sh",
    "dev:macos": "npm run build:macos && open apps/macos-app/dist/Phived.app",
    "lint": "npm run lint --workspace apps/web",
    "preview": "npm run preview --workspace apps/web",
    "test:macos": "npm run build:macos && PHIVED_SELF_TEST=1 apps/macos-app/dist/Phived.app/Contents/MacOS/Phived",
    "test:macos:xctest": "swift test --package-path apps/macos-app"
  }
}
